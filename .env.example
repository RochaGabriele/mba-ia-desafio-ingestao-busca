# === Google Gemini ===
# Crie a chave em https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# === Banco de dados (PostgreSQL + pgVector) ===
# Driver psycopg (v3) exigido pelo langchain-postgres.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag

# Nome da coleção onde os vetores são salvos.
PGVECTOR_COLLECTION=pdf_documents

# Caminho do PDF a ser ingerido (relativo à raiz do projeto).
PDF_PATH=document.pdf

# Modelos Gemini (pode trocar se algum ficar indisponível).
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
GOOGLE_LLM_MODEL=gemini-2.5-flash-lite
